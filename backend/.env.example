# ==============================================================================
# DevTrack Spring Boot Backend Environment Variables
# Rename this file to '.env' and populate with your configuration.
# Do NOT commit your actual '.env' file to version control.
# ==============================================================================

# Active Spring Profile (use 'prod' for production and Render deployments)
SPRING_PROFILES_ACTIVE=prod

# JDBC Datasource Configuration (e.g. Railway MySQL database)
# Syntax for Railway MySQL: jdbc:mysql://<HOST>:<PORT>/<DATABASE>?useSSL=true&requireSSL=true&serverTimezone=UTC&allowPublicKeyRetrieval=true
SPRING_DATASOURCE_URL=jdbc:mysql://your-railway-mysql-host.railway.internal:3306/railway?useSSL=true&requireSSL=true&serverTimezone=UTC&allowPublicKeyRetrieval=true
SPRING_DATASOURCE_USERNAME=root
SPRING_DATASOURCE_PASSWORD=your_secure_railway_database_password

# JWT Security Configurations
# Secret must be a hex-encoded string of at least 256 bits (64 characters)
JWT_SECRET=407f3f61556942b083321cb17036d0bc6cff4bf51a2d5ad5a7c36a6cf9df8268cfb8414fa9cf0ee86d11f6213702be9d9f5ad30424564c703b418fb5ff45db11
devtrack.jwt.expiration-ms=86400000

# Application Port
PORT=8080
